class Solution {
    public void rotate(int[] nums, int k) {
        int n = nums.length;
        k = k%n;
        reversenum(nums,0,n-1);
        reversenum(nums,0,k-1);
        reversenum(nums,k,n-1);
        
         }

         static void reversenum(int[] nums,int i, int j){
            int temp=0;
            while(i<j){
          temp =nums[i];
          nums[i]=nums[j];
          nums[j]=temp;
           i++;
           j--;
        
        }
        
         }
}

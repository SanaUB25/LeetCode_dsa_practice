class Solution {
    public int largestAltitude(int[] gain) {
        int sum =0;
        int[] element = new int[gain.length];
        int k =0;
        for(int i = 0; i<gain.length;i++){
        sum = sum + gain[i];
        element[k] = sum ;
        k++;
        }
      int max = 0;
        for(int i =0 ; i<element.length;i++){
if(element[i]>max){
    max = element[i];
}

        }
        return max;
    }
}
